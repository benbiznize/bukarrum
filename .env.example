# ─── Supabase ───────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key   # Never expose this client-side

# ─── Resend (transactional email) ────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must match a verified domain or use onboarding@resend.dev for testing
RESEND_FROM_EMAIL=bookings@yourstudio.com

# ─── Fintoc (Chilean bank transfer payments) ─────────────────────────────────
# https://dashboard.fintoc.com → Developers → API Keys
NEXT_PUBLIC_FINTOC_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx  # safe to expose client-side
FINTOC_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# Secret for validating Fintoc webhook signatures
FINTOC_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
